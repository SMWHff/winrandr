# Auto-detect and normalize text files
* text=auto

# Shell scripts must stay LF
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=lf
*.psm1 text eol=lf

# Python files
*.py text eol=lf

# Markdown/docs
*.md text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Lock files - binary
uv.lock binary
*.lock binary

# Generated/build artifacts
*.exe binary
*.dll binary
*.pyc binary
*.zip binary
*.ico binary
*.png binary
*.jpg binary

# Editor/IDE
.editorconfig text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
